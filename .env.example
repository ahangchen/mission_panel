# Mission Panel Environment Configuration
# Copy this file to .env and modify as needed

# Application settings
APP_NAME=Mission Panel
DEBUG=false

# Database settings
DATABASE_URL=sqlite:///./data/mission_panel.db

# Data directories (mounted in docker-compose)
OPENCLAW_DATA_DIR=/data/openclaw
CODING_DIR=/data/coding

# CORS settings (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# File browser settings
MAX_FILE_SIZE=5242880

# Frontend API URL (for client-side requests)
REACT_APP_API_URL=http://localhost:8000
